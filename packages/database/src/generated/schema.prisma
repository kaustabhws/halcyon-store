// Enums shared across domains.

enum CustomerStatus {
  ACTIVE
  SUSPENDED
  DELETED
}

enum AddressType {
  BILLING
  SHIPPING
  BOTH
}

enum AdminStatus {
  ACTIVE
  INVITED
  SUSPENDED
}

enum ProductKind {
  PHYSICAL
  DIGITAL
  SERVICE
  SUBSCRIPTION
  BUNDLE
  KIT
  COURSE
}

enum ProductStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum AttributeKind {
  LIST
  TEXT
  NUMBER
  SWATCH
}

enum StockReason {
  PURCHASE
  SALE
  RETURN
  ADJUSTMENT
  RESERVATION
  RELEASE
  DAMAGE
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  RETURNED
  REFUNDED
  FAILED
}

enum FulfillmentStatus {
  UNFULFILLED
  PARTIAL
  FULFILLED
}

enum ShipmentStatus {
  PENDING
  LABELED
  IN_TRANSIT
  OUT_FOR_DELIVERY
  DELIVERED
  FAILED
  RETURNED
}

enum PaymentProvider {
  RAZORPAY
  STRIPE
  PAYPAL
  CASHFREE
  WALLET
  COD
  GIFT_CARD
  STORE_CREDIT
}

enum PaymentIntentStatus {
  REQUIRES_ACTION
  PROCESSING
  AUTHORIZED
  CAPTURED
  FAILED
  REFUNDED
  PARTIAL_REFUND
}

enum PaymentTxnKind {
  AUTH
  CAPTURE
  REFUND
  VOID
}

enum WebhookStatus {
  PENDING
  DELIVERED
  FAILED
  DEAD_LETTER
}

enum CouponType {
  PERCENT
  FIXED
  FREE_SHIPPING
}

enum PromotionScope {
  CART
  PRODUCT
  CATEGORY
  BRAND
  COLLECTION
}

enum RefundStatus {
  PROCESSING
  SUCCEEDED
  FAILED
}

enum ActorKind {
  CUSTOMER
  ADMIN
  SYSTEM
}

enum OutboxStatus {
  PENDING
  PROCESSED
  FAILED
}

// Cart domain — anonymous (token) or customer-owned. Cart items snapshot
// price at add-time; totals recomputed at checkout. Optimistic concurrency
// via version column.

model Cart {
  id             String    @id @default(cuid())
  customerId     String?
  anonymousToken String?   @unique
  currency       String    @default("INR")
  subtotalMinor  BigInt    @default(0)
  discountMinor  BigInt    @default(0)
  shippingMinor  BigInt    @default(0)
  totalMinor     BigInt    @default(0)
  couponCode     String?
  version        Int       @default(0)
  expiresAt      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  customer Customer?  @relation(fields: [customerId], references: [id], onDelete: SetNull)
  items    CartItem[]

  @@index([customerId])
  @@index([updatedAt])
}

model CartItem {
  id             String @id @default(cuid())
  cartId         String
  variantId      String
  quantity       Int
  unitPriceMinor BigInt // snapshot
  currency       String @default("INR")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cart    Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  variant Variant @relation(fields: [variantId], references: [id])

  @@unique([cartId, variantId])
  @@index([variantId])
}

// Catalog domain — categories (nested), brands, products, variants,
// attributes, media. Translation tables present but unused at MVP
// (en-IN only).

model Category {
  id          String  @id @default(cuid())
  vendorId    String
  parentId    String?
  slug        String
  name        String
  description String? @db.Text
  position    Int     @default(0)
  imageUrl    String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  vendor   Vendor            @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  parent   Category?         @relation("CategoryToCategory", fields: [parentId], references: [id], onDelete: SetNull)
  children Category[]        @relation("CategoryToCategory")
  products ProductCategory[]

  @@unique([vendorId, slug])
  @@index([parentId])
  @@index([deletedAt])
}

model Brand {
  id          String  @id @default(cuid())
  vendorId    String
  slug        String
  name        String
  description String? @db.Text
  logoUrl     String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  vendor   Vendor    @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  products Product[]

  @@unique([vendorId, slug])
  @@index([deletedAt])
}

model Product {
  id               String        @id @default(cuid())
  vendorId         String
  kind             ProductKind   @default(PHYSICAL)
  status           ProductStatus @default(DRAFT)
  brandId          String?
  slug             String
  name             String
  shortDescription String?       @db.Text
  description      String?       @db.Text
  hasVariants      Boolean       @default(false)
  /// When true, ProductMedia rows tagged with an attribute value are filtered
  /// by the currently-selected value of `imageAttribute` on the storefront.
  /// When false, all images show for every variant (single shared gallery).
  useVariantImages Boolean       @default(false)
  /// The attribute whose values drive per-image grouping (e.g. Color). When
  /// set with useVariantImages, the storefront swaps images as the customer
  /// changes this attribute's value. Null = no attribute chosen yet.
  imageAttributeId String?
  isFeatured       Boolean       @default(false)
  defaultVariantId String?       @unique

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  vendor         Vendor     @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  brand          Brand?     @relation(fields: [brandId], references: [id], onDelete: SetNull)
  defaultVariant Variant?   @relation("ProductDefaultVariant", fields: [defaultVariantId], references: [id], onDelete: SetNull)
  imageAttribute Attribute? @relation("ProductImageAttribute", fields: [imageAttributeId], references: [id], onDelete: SetNull)

  variants       Variant[]         @relation("ProductVariants")
  categories     ProductCategory[]
  media          ProductMedia[]
  reviews        Review[]
  wishlistItems  WishlistItem[]
  specifications Specification[]

  @@unique([vendorId, slug])
  @@index([status, isFeatured, createdAt])
  @@index([brandId])
  @@index([deletedAt])
}

model ProductCategory {
  productId  String
  categoryId String
  position   Int    @default(0)

  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([productId, categoryId])
  @@index([categoryId])
}

model ProductMedia {
  id               String  @id @default(cuid())
  productId        String
  /// Deprecated for the new image model — kept for backward compatibility.
  /// New per-attribute images use `attributeValueId` instead.
  variantId        String?
  /// When set, this image belongs to a specific attribute value (e.g. the
  /// "Black" value of the Color attribute). The storefront shows it when the
  /// customer selects that value. Null = shared across all values.
  attributeValueId String?
  url              String
  altText          String?
  position         Int     @default(0)
  isPrimary        Boolean @default(false)
  cloudinaryId     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  product        Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant        Variant?        @relation(fields: [variantId], references: [id], onDelete: SetNull)
  attributeValue AttributeValue? @relation(fields: [attributeValueId], references: [id], onDelete: SetNull)

  @@index([productId, position])
  @@index([variantId])
  @@index([attributeValueId])
}

model Variant {
  id          String  @id @default(cuid())
  productId   String
  sku         String
  barcode     String?
  name        String? // e.g. "UK 10 / Black"
  weightGrams Int?
  isDefault   Boolean @default(false)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  product           Product  @relation("ProductVariants", fields: [productId], references: [id], onDelete: Cascade)
  defaultForProduct Product? @relation("ProductDefaultVariant")

  prices       Price[]
  inventory    InventoryLevel[]
  attributes   VariantAttributeValue[]
  orderItems   OrderItem[]
  cartItems    CartItem[]
  reservations InventoryReservation[]
  movements    InventoryMovement[]
  media        ProductMedia[]

  @@unique([productId, sku])
  @@index([barcode])
  @@index([deletedAt])
}

model Attribute {
  id       String        @id @default(cuid())
  vendorId String
  code     String // "color", "size"
  label    String
  kind     AttributeKind @default(LIST)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vendor        Vendor           @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  values        AttributeValue[]
  imageProducts Product[]        @relation("ProductImageAttribute")

  @@unique([vendorId, code])
}

model AttributeValue {
  id          String  @id @default(cuid())
  attributeId String
  value       String // canonical (lowercase) — "black", "uk-10"
  label       String // human — "Black", "UK 10"
  swatchHex   String?
  position    Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  attribute Attribute               @relation(fields: [attributeId], references: [id], onDelete: Cascade)
  variants  VariantAttributeValue[]
  media     ProductMedia[]

  @@unique([attributeId, value])
}

model VariantAttributeValue {
  variantId        String
  attributeValueId String

  variant        Variant        @relation(fields: [variantId], references: [id], onDelete: Cascade)
  attributeValue AttributeValue @relation(fields: [attributeValueId], references: [id], onDelete: Cascade)

  @@id([variantId, attributeValueId])
  @@index([attributeValueId])
}

model Specification {
  id        String @id @default(cuid())
  productId String
  key       String
  value     String @db.Text
  position  Int    @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, position])
}

// Engagement domain — reviews. Q&A lands later.

model Review {
  id           String  @id @default(cuid())
  productId    String
  customerId   String
  orderItemId  String? // verified-purchase signal
  rating       Int // 1..5
  title        String?
  body         String  @db.Text
  status       String  @default("PENDING") // PENDING|APPROVED|REJECTED|SPAM
  helpfulCount Int     @default(0)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id])

  @@unique([productId, customerId])
  @@index([productId, status, createdAt])
  @@index([customerId])
  @@index([deletedAt])
}

// IAM domain — admins managed via Clerk; we cache the Clerk userId and
// own roles + permissions ourselves so RBAC stays platform-controlled.

model Admin {
  id          String      @id @default(cuid())
  clerkUserId String      @unique
  email       String      @unique
  firstName   String?
  lastName    String?
  status      AdminStatus @default(ACTIVE)
  lastLoginAt DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  roleAssignments RoleAssignment[]

  @@index([deletedAt])
}

model Role {
  id          String  @id @default(cuid())
  name        String  @unique
  description String?
  isSystem    Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  permissions RolePermission[]
  assignments RoleAssignment[]
}

model Permission {
  id          String  @id @default(cuid())
  key         String  @unique // e.g. "order.refund"
  resource    String
  action      String
  description String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  roles RolePermission[]
}

model RolePermission {
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([permissionId])
}

model RoleAssignment {
  id       String  @id @default(cuid())
  adminId  String
  roleId   String
  vendorId String? // null = platform-wide; ready for multi-vendor

  createdAt DateTime @default(now())

  admin  Admin   @relation(fields: [adminId], references: [id], onDelete: Cascade)
  role   Role    @relation(fields: [roleId], references: [id], onDelete: Cascade)
  vendor Vendor? @relation(fields: [vendorId], references: [id], onDelete: SetNull)

  @@unique([adminId, roleId, vendorId])
  @@index([adminId])
  @@index([roleId])
}

// Audit log — everything mutating in admin writes one row here.
model AuditLog {
  id         String    @id @default(cuid())
  actorKind  ActorKind
  actorId    String?
  entityType String
  entityId   String
  action     String
  before     Json?
  after      Json?
  ipAddress  String?
  userAgent  String?   @db.Text

  createdAt DateTime @default(now())

  @@index([actorId, createdAt])
  @@index([entityType, entityId, createdAt])
}

// Identity domain — customers, sessions, addresses, devices.

model Customer {
  id             String         @id @default(cuid())
  email          String         @unique
  emailVerified  DateTime?
  phone          String?
  passwordHash   String?
  firstName      String?
  lastName       String?
  status         CustomerStatus @default(ACTIVE)
  locale         String         @default("en-IN")
  currency       String         @default("INR")
  marketingOptIn Boolean        @default(false)
  lastLoginAt    DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  addresses     Address[]
  sessions      CustomerSession[]
  devices       Device[]
  carts         Cart[]
  orders        Order[]
  reviews       Review[]
  oauthAccounts OAuthAccount[]
  wishlistItems WishlistItem[]

  @@index([deletedAt])
  @@index([createdAt])
}

/**
 * Customer ↔ Product wishlist. Single flat table — no `Wishlist` parent —
 * since customers have one default wishlist for now. Adding named lists is
 * a future feature; the unique key would change to (customerId, listId,
 * productId).
 */
model WishlistItem {
  id         String @id @default(cuid())
  customerId String
  productId  String

  createdAt DateTime @default(now())

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([customerId, productId])
  @@index([customerId, createdAt])
  @@index([productId])
}

model OAuthAccount {
  id                String    @id @default(cuid())
  customerId        String
  provider          String
  providerAccountId String
  accessToken       String?   @db.Text
  refreshToken      String?   @db.Text
  expiresAt         DateTime?
  scope             String?
  tokenType         String?
  idToken           String?   @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([customerId])
}

model CustomerSession {
  id         String    @id @default(cuid())
  customerId String
  token      String    @unique
  ipAddress  String?
  userAgent  String?   @db.Text
  deviceId   String?
  expiresAt  DateTime
  revokedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  device   Device?  @relation(fields: [deviceId], references: [id], onDelete: SetNull)

  @@index([customerId])
  @@index([expiresAt])
}

model Device {
  id          String   @id @default(cuid())
  customerId  String
  fingerprint String
  name        String?
  lastSeenAt  DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  customer Customer          @relation(fields: [customerId], references: [id], onDelete: Cascade)
  sessions CustomerSession[]

  @@unique([customerId, fingerprint])
  @@index([customerId])
}

model Address {
  id         String      @id @default(cuid())
  customerId String
  type       AddressType @default(SHIPPING)
  fullName   String
  phone      String?
  line1      String
  line2      String?
  city       String
  state      String
  postalCode String
  country    String      @default("IN")
  isDefault  Boolean     @default(false)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([deletedAt])
}

// Inventory domain — warehouses, levels, reservations, movements.
// Money fields use BIGINT (amountMinor) + currency CHAR(3) per architecture.

model Warehouse {
  id        String  @id @default(cuid())
  vendorId  String
  code      String
  name      String
  city      String?
  state     String?
  country   String  @default("IN")
  isDefault Boolean @default(false)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  vendor       Vendor                 @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  levels       InventoryLevel[]
  reservations InventoryReservation[]
  movements    InventoryMovement[]

  @@unique([vendorId, code])
  @@index([deletedAt])
}

model InventoryLevel {
  id          String @id @default(cuid())
  warehouseId String
  variantId   String
  onHand      Int    @default(0)
  reserved    Int    @default(0)
  incoming    Int    @default(0)
  version     Int    @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  warehouse Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  variant   Variant   @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([warehouseId, variantId])
  @@index([variantId])
}

model InventoryReservation {
  id          String    @id @default(cuid())
  variantId   String
  warehouseId String
  quantity    Int
  orderId     String?
  cartId      String?
  expiresAt   DateTime
  releasedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  variant   Variant   @relation(fields: [variantId], references: [id], onDelete: Cascade)
  warehouse Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  @@index([variantId])
  @@index([orderId])
  @@index([cartId])
  @@index([expiresAt])
}

model InventoryMovement {
  id            String      @id @default(cuid())
  variantId     String
  warehouseId   String
  quantity      Int // signed
  reason        StockReason
  referenceType String?
  referenceId   String?
  costMinor     BigInt?
  currency      String?

  createdAt DateTime @default(now())

  variant   Variant   @relation(fields: [variantId], references: [id], onDelete: Cascade)
  warehouse Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  @@index([variantId, createdAt])
  @@index([warehouseId, createdAt])
}

// Datasource + generator
// Multi-file schema enabled via the `prismaSchemaFolder` preview feature.
// All other .prisma files in this folder are merged into one schema.

generator client {
  provider        = "prisma-client-js"
  output          = "../../src/generated"
  previewFeatures = ["prismaSchemaFolder"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Marketing domain — minimal MVP: coupons + redemption tracking.
// Promotions / campaigns / referrals land in later phases on the same shape.

model Coupon {
  id               String         @id @default(cuid())
  vendorId         String
  code             String         @unique
  type             CouponType
  value            Int // percent (0-100) OR fixed amount in minor units
  currency         String? // null for PERCENT/FREE_SHIPPING
  scope            PromotionScope @default(CART)
  targetIds        Json?
  minSubtotalMinor BigInt?
  maxRedemptions   Int?
  perCustomerLimit Int?
  validFrom        DateTime?
  validTo          DateTime?
  active           Boolean        @default(true)

  redemptionsCount Int @default(0)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  vendor      Vendor             @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  redemptions CouponRedemption[]

  @@index([active, validFrom, validTo])
  @@index([deletedAt])
}

model CouponRedemption {
  id         String @id @default(cuid())
  couponId   String
  customerId String
  orderId    String

  createdAt DateTime @default(now())

  coupon Coupon @relation(fields: [couponId], references: [id], onDelete: Cascade)

  @@unique([couponId, orderId])
  @@index([customerId])
}

// Order domain — orders, items, timeline, fulfillment, shipments.
// Orders snapshot product data at the time of purchase so subsequent
// catalog edits don't mutate history.

model Order {
  id          String @id @default(cuid())
  orderNumber String @unique
  vendorId    String
  customerId  String
  currency    String @default("INR")

  subtotalMinor BigInt @default(0)
  discountMinor BigInt @default(0)
  shippingMinor BigInt @default(0)
  taxMinor      BigInt @default(0)
  totalMinor    BigInt @default(0)

  status            OrderStatus       @default(PENDING)
  fulfillmentStatus FulfillmentStatus @default(UNFULFILLED)
  placedAt          DateTime          @default(now())
  cancelledAt       DateTime?

  shippingAddress Json
  billingAddress  Json?
  couponCode      String?
  notes           String? @db.Text

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  vendor   Vendor   @relation(fields: [vendorId], references: [id])
  customer Customer @relation(fields: [customerId], references: [id])

  items               OrderItem[]
  timeline            OrderTimelineEvent[]
  fulfillments        Fulfillment[]
  paymentIntents      PaymentIntent[]
  paymentTransactions PaymentTransaction[]
  refunds             Refund[]

  @@index([customerId, createdAt])
  @@index([status, createdAt])
  @@index([vendorId, status])
  @@index([deletedAt])
}

model OrderItem {
  id                String            @id @default(cuid())
  orderId           String
  variantId         String
  productSnapshot   Json // name, sku, image, brand, attributes — captured at order time
  quantity          Int
  unitPriceMinor    BigInt
  discountMinor     BigInt            @default(0)
  taxMinor          BigInt            @default(0)
  totalMinor        BigInt
  fulfillmentStatus FulfillmentStatus @default(UNFULFILLED)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variant Variant @relation(fields: [variantId], references: [id])

  shipmentItems ShipmentItem[]

  @@index([orderId])
  @@index([variantId])
}

model OrderTimelineEvent {
  id        String    @id @default(cuid())
  orderId   String
  type      String // "order.placed", "order.confirmed", "payment.captured", ...
  message   String?
  payload   Json?
  actorKind ActorKind @default(SYSTEM)
  actorId   String?

  createdAt DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId, createdAt])
}

model Fulfillment {
  id          String            @id @default(cuid())
  orderId     String
  warehouseId String?
  status      FulfillmentStatus @default(UNFULFILLED)
  shippedAt   DateTime?
  deliveredAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  order     Order      @relation(fields: [orderId], references: [id], onDelete: Cascade)
  shipments Shipment[]

  @@index([orderId])
}

model Shipment {
  id             String         @id @default(cuid())
  fulfillmentId  String
  carrier        String
  service        String
  trackingNumber String         @unique
  trackingUrl    String?
  labelUrl       String?
  status         ShipmentStatus @default(PENDING)
  shippedAt      DateTime?
  deliveredAt    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  fulfillment Fulfillment    @relation(fields: [fulfillmentId], references: [id], onDelete: Cascade)
  items       ShipmentItem[]

  @@index([fulfillmentId])
}

model ShipmentItem {
  id          String @id @default(cuid())
  shipmentId  String
  orderItemId String
  quantity    Int

  shipment  Shipment  @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  orderItem OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)

  @@index([shipmentId])
  @@index([orderItemId])
}

// Payment domain — provider-agnostic intent/transaction model.
// Razorpay impl writes here; future Stripe etc. reuse the same tables.

model PaymentIntent {
  id               String              @id @default(cuid())
  orderId          String
  provider         PaymentProvider
  providerIntentId String? // razorpayOrderId etc.
  amountMinor      BigInt
  currency         String              @default("INR")
  status           PaymentIntentStatus @default(REQUIRES_ACTION)
  idempotencyKey   String              @unique
  clientPayload    Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  order    Order            @relation(fields: [orderId], references: [id], onDelete: Cascade)
  attempts PaymentAttempt[]

  @@unique([provider, providerIntentId])
  @@index([orderId])
  @@index([status, createdAt])
}

model PaymentAttempt {
  id              String              @id @default(cuid())
  paymentIntentId String
  attemptNumber   Int
  status          PaymentIntentStatus
  errorCode       String?
  errorMessage    String?             @db.Text
  providerPayload Json?

  createdAt DateTime @default(now())

  intent PaymentIntent @relation(fields: [paymentIntentId], references: [id], onDelete: Cascade)

  @@index([paymentIntentId])
}

model PaymentTransaction {
  id            String              @id @default(cuid())
  orderId       String
  provider      PaymentProvider
  providerTxnId String
  kind          PaymentTxnKind
  amountMinor   BigInt
  currency      String              @default("INR")
  status        PaymentIntentStatus
  capturedAt    DateTime?
  raw           Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  order   Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  refunds Refund[]

  @@unique([provider, providerTxnId])
  @@index([orderId])
  @@index([status, createdAt])
}

model Refund {
  id                   String       @id @default(cuid())
  orderId              String
  paymentTransactionId String
  amountMinor          BigInt
  currency             String       @default("INR")
  reason               String?
  status               RefundStatus @default(PROCESSING)
  providerRefundId     String?
  processedAt          DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  order       Order              @relation(fields: [orderId], references: [id], onDelete: Cascade)
  transaction PaymentTransaction @relation(fields: [paymentTransactionId], references: [id])

  @@index([orderId])
}

model WebhookEvent {
  id              String          @id @default(cuid())
  provider        PaymentProvider
  providerEventId String
  type            String
  payload         Json
  signatureValid  Boolean
  status          WebhookStatus   @default(PENDING)
  attempts        Int             @default(0)
  receivedAt      DateTime        @default(now())
  processedAt     DateTime?
  error           String?         @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([provider, providerEventId])
  @@index([status, createdAt])
}

// Pricing domain — simplified for MVP. Single price list per vendor;
// variant-level prices with optional compareAt for "sale" display.
// Future tier/group/region pricing fits this shape without rewriting.

model PriceList {
  id        String  @id @default(cuid())
  vendorId  String
  code      String
  name      String
  currency  String  @default("INR")
  isDefault Boolean @default(false)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  prices Price[]

  @@unique([vendorId, code])
  @@index([deletedAt])
}

model Price {
  id                   String  @id @default(cuid())
  priceListId          String
  variantId            String
  amountMinor          BigInt
  compareAtAmountMinor BigInt?
  currency             String  @default("INR")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  priceList PriceList @relation(fields: [priceListId], references: [id], onDelete: Cascade)
  variant   Variant   @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([priceListId, variantId])
  @@index([variantId])
}

// System domain — outbox (events), idempotency keys, settings.

model OutboxEvent {
  id            String       @id @default(cuid())
  aggregateType String // "order", "product", "payment"...
  aggregateId   String
  type          String // "order.placed", "product.updated"...
  payload       Json
  status        OutboxStatus @default(PENDING)
  attempts      Int          @default(0)
  processedAt   DateTime?
  error         String?      @db.Text

  createdAt DateTime @default(now())

  @@index([status, createdAt])
  @@index([aggregateType, aggregateId])
}

model IdempotencyKey {
  key         String   @id
  scope       String
  requestHash String
  response    Json?
  createdAt   DateTime @default(now())
  expiresAt   DateTime

  @@index([expiresAt])
}

model Setting {
  id       String  @id @default(cuid())
  vendorId String?
  scope    String  @default("PLATFORM")
  key      String
  value    Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([scope, vendorId, key])
}

// Tenancy — single vendor at MVP. Every catalog/inventory/order/coupon row
// carries vendorId so multi-vendor is a column-level change later, not a
// schema rewrite.

model Vendor {
  id         String  @id @default(cuid())
  slug       String  @unique
  name       String
  isPlatform Boolean @default(false)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  products        Product[]
  warehouses      Warehouse[]
  orders          Order[]
  coupons         Coupon[]
  brands          Brand[]
  categories      Category[]
  attributes      Attribute[]
  roleAssignments RoleAssignment[]
}
