{
  "name": "@ecom/database",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./client": "./src/client.ts",
    "./generated": "./src/generated/index.ts"
  },
  "scripts": {
    "lint": "echo 'ok'",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf .turbo dist src/generated",
    "postinstall": "prisma generate",
    "db:generate": "dotenv -e ../../.env -- prisma generate",
    "db:migrate": "dotenv -e ../../.env -- prisma migrate dev",
    "db:migrate:deploy": "dotenv -e ../../.env -- prisma migrate deploy",
    "db:push": "dotenv -e ../../.env -- prisma db push",
    "db:studio": "dotenv -e ../../.env -- prisma studio",
    "db:seed": "dotenv -e ../../.env -- tsx prisma/seed.ts"
  },
  "prisma": {
    "schema": "prisma/schema",
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@ecom/shared": "*",
    "@prisma/client": "6.5.0"
  },
  "devDependencies": {
    "@ecom/tsconfig": "*",
    "@types/node": "^20",
    "dotenv-cli": "^8.0.0",
    "prisma": "6.5.0",
    "tsx": "^4.19.2",
    "typescript": "^5"
  }
}
