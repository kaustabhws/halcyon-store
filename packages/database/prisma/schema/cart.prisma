// Cart domain — anonymous (token) or customer-owned. Cart items snapshot
// price at add-time; totals recomputed at checkout. Optimistic concurrency
// via version column.

model Cart {
  id              String    @id @default(cuid())
  customerId      String?
  anonymousToken  String?   @unique
  currency        String    @default("INR")
  subtotalMinor   BigInt    @default(0)
  discountMinor   BigInt    @default(0)
  shippingMinor   BigInt    @default(0)
  totalMinor      BigInt    @default(0)
  couponCode      String?
  version         Int       @default(0)
  expiresAt       DateTime?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  customer        Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  items           CartItem[]

  @@index([customerId])
  @@index([updatedAt])
}

model CartItem {
  id              String   @id @default(cuid())
  cartId          String
  variantId       String
  quantity        Int
  unitPriceMinor  BigInt   // snapshot
  currency        String   @default("INR")

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  cart            Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  variant         Variant  @relation(fields: [variantId], references: [id])

  @@unique([cartId, variantId])
  @@index([variantId])
}
