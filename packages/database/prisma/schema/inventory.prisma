// Inventory domain — warehouses, levels, reservations, movements.
// Money fields use BIGINT (amountMinor) + currency CHAR(3) per architecture.

model Warehouse {
  id          String   @id @default(cuid())
  vendorId    String
  code        String
  name        String
  city        String?
  state       String?
  country     String   @default("IN")
  isDefault   Boolean  @default(false)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  vendor      Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  levels      InventoryLevel[]
  reservations InventoryReservation[]
  movements   InventoryMovement[]

  @@unique([vendorId, code])
  @@index([deletedAt])
}

model InventoryLevel {
  id           String   @id @default(cuid())
  warehouseId  String
  variantId    String
  onHand       Int      @default(0)
  reserved     Int      @default(0)
  incoming     Int      @default(0)
  version      Int      @default(0)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  warehouse    Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  variant      Variant   @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([warehouseId, variantId])
  @@index([variantId])
}

model InventoryReservation {
  id          String    @id @default(cuid())
  variantId   String
  warehouseId String
  quantity    Int
  orderId     String?
  cartId      String?
  expiresAt   DateTime
  releasedAt  DateTime?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  variant     Variant   @relation(fields: [variantId], references: [id], onDelete: Cascade)
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  @@index([variantId])
  @@index([orderId])
  @@index([cartId])
  @@index([expiresAt])
}

model InventoryMovement {
  id            String      @id @default(cuid())
  variantId     String
  warehouseId   String
  quantity      Int         // signed
  reason        StockReason
  referenceType String?
  referenceId   String?
  costMinor     BigInt?
  currency      String?

  createdAt     DateTime    @default(now())

  variant       Variant     @relation(fields: [variantId], references: [id], onDelete: Cascade)
  warehouse     Warehouse   @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  @@index([variantId, createdAt])
  @@index([warehouseId, createdAt])
}
