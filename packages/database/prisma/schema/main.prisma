// Datasource + generator
// Multi-file schema enabled via the `prismaSchemaFolder` preview feature.
// All other .prisma files in this folder are merged into one schema.

generator client {
  provider        = "prisma-client-js"
  output          = "../../src/generated"
  previewFeatures = ["prismaSchemaFolder"]
  // "native" covers local dev; "rhel-openssl-3.0.x" is the engine Vercel's
  // serverless runtime (Node 20, Amazon Linux) needs at runtime.
  binaryTargets   = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
