// Datasource + generator
// Multi-file schema enabled via the `prismaSchemaFolder` preview feature.
// All other .prisma files in this folder are merged into one schema.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["prismaSchemaFolder"]
  // Default output (node_modules/.prisma/client) so Vercel + Next's
  // serverExternalPackages can locate the query engine at runtime.
  // "native" covers local dev; "rhel-openssl-3.0.x" is the engine Vercel's
  // serverless runtime (Node 20, Amazon Linux) needs.
  binaryTargets   = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
